{
  // 推荐安装的扩展列表
  "recommendations": [
    // ESLint 代码检查
    "dbaeumer.vscode-eslint",
    // Stylelint 样式检查
    "stylelint.vscode-stylelint",
    // Prettier 代码格式化
    "esbenp.prettier-vscode",
    // Vue 开发必备（语法高亮、智能提示）
    "Vue.volar",
    // TypeScript 支持（Vue 3 推荐）
    "Vue.vscode-typescript-vue-plugin",
    // 自动闭合标签
    "formulahendry.auto-close-tag",
    // 自动重命名标签（配合Vue模板使用）
    "formulahendry.auto-rename-tag",
    // Git 集成增强（显示行内修改、提交历史）
    "eamodio.gitlens",
    // .env 文件语法高亮
    "mikestead.dotenv",
    // SCSS 语法支持
    "syler.sass-indented",
    // XML 格式化（适用于 manifest.json 等文件）
    "redhat.vscode-xml"
  ]
}
