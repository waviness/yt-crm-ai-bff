{
  "name": "uni-preset-vue",
  "version": "0.0.0",
  "scripts": {
    "postinstall": "pnpm run generate:types",
    "generate:types": "vite build --mode generate || true",
    "dev:custom": "uni -p",
    "dev:h5": "uni",
    "dev:h5:ssr": "uni --ssr",
    "dev:mp-alipay": "uni -p mp-alipay",
    "dev:mp-baidu": "uni -p mp-baidu",
    "dev:mp-jd": "uni -p mp-jd",
    "dev:mp-kuaishou": "uni -p mp-kuaishou",
    "dev:mp-lark": "uni -p mp-lark",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:mp-toutiao": "uni -p mp-toutiao",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:mp-xhs": "uni -p mp-xhs",
    "dev:quickapp-webview": "uni -p quickapp-webview",
    "dev:quickapp-webview-huawei": "uni -p quickapp-webview-huawei",
    "dev:quickapp-webview-union": "uni -p quickapp-webview-union",
    "build:custom": "uni build -p",
    "build:h5": "uni build",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "uni build -p mp-alipay",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:mp-jd": "uni build -p mp-jd",
    "build:mp-kuaishou": "uni build -p mp-kuaishou",
    "build:mp-lark": "uni build -p mp-lark",
    "build:mp-qq": "uni build -p mp-qq",
    "build:mp-toutiao": "uni build -p mp-toutiao",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:mp-xhs": "uni build -p mp-xhs",
    "build:quickapp-webview": "uni build -p quickapp-webview",
    "build:quickapp-webview-huawei": "uni build -p quickapp-webview-huawei",
    "build:quickapp-webview-union": "uni build -p quickapp-webview-union",
    "type-check": "vue-tsc --noEmit",
    "check-git-config": "node -e \"const {execSync} = require('child_process'); const crlf = execSync('git config core.autocrlf').toString().trim(); if(crlf !== 'input') { console.error('请执行：git config --global core.autocrlf input'); process.exit(1); }\"",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "update:iconfont": "set NODE_NO_WARNINGS=1 && node node_modules/iconfont-tools-cli/lib/cli.js --config config/iconfont.config.js --to ./src/static/iconfont",
    "format": "prettier --write \"src/**/*.{vue,js,ts,jsx,tsx,json,css,scss}\" \"api/**/*.ts\"",
    "prepare": "husky",
    "lint": "eslint --fix",
    "preview": "serve ./dist/build/h5",
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-plus": "3.0.0-4080720251210001",
    "@dcloudio/uni-components": "3.0.0-4080720251210001",
    "@dcloudio/uni-h5": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-jd": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-lark": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-qq": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4080720251210001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4080720251210001",
    "clipboard": "^2.0.11",
    "dayjs": "^1.11.13",
    "lodash.orderby": "^4.6.0",
    "pinia": "^2.3.1",
    "sortablejs": "^1.15.6",
    "tslib": "^2.8.1",
    "uview-plus": "^3.5.41",
    "vconsole": "^3.15.1",
    "vue": "^3.4.21",
    "vue-i18n": "^9.1.9",
    "weixin-jsapi": "^1.1.0"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.0",
    "@babel/runtime": "^7.28.4",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080720251210001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080720251210001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080720251210001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080720251210001",
    "@types/lodash.orderby": "^4.6.9",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@unocss/transformer-directives": "0.61.9",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/runtime-core": "^3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.1.3",
    "complex.js": "^2.4.2",
    "decimal.js": "^10.6.0",
    "escape-latex": "^1.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-vue": "^10.3.0",
    "fraction.js": "^5.3.4",
    "husky": "^9.1.7",
    "iconfont-tools-cli": "^1.3.1",
    "javascript-natural-sort": "^0.7.1",
    "jiti": "^2.5.1",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "1.78.0",
    "seedrandom": "^3.0.5",
    "serve": "^14.2.4",
    "stylelint": "^16.23.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-config-standard-vue": "^1.0.0",
    "tiny-emitter": "^2.1.0",
    "typed-function": "^4.2.1",
    "typescript": "^4.9.4",
    "unocss": "^0.61.9",
    "unocss-preset-weapp": "^0.61.1",
    "unplugin-auto-import": "^19.3.0",
    "vite": "5.2.8",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^1.0.24",
    "vercel": "^37.0.0"
  },
  "lint-staged": {
    "*.{css,scss}": [
      "stylelint --fix --allow-empty-input"
    ],
    "*.{vue,js,ts,jsx,tsx}": [
      "eslint --fix",
      "node scripts/check-filename.js"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
